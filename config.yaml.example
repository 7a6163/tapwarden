# tapwarden configuration — copy to ~/.config/tapwarden/config.yaml and chmod 0600.
# (Vaultwarden backend: `tapwarden setup` writes this file for you.)
# The access token itself lives ONLY in the env var named below, never here.

# Secret backend: bws (default, Bitwarden Secrets Manager) | vaultwarden.
# backend: bws
access_token_env: BWS_ACCESS_TOKEN

# Where the BWS access token comes from: env (default) | keychain.
# env      = read from the var named by access_token_env (CI / --fg use).
# keychain = read from the macOS Keychain (store it with `tapwarden store-token`).
#            Use this for the background agent: launchd does not inherit your
#            shell env, so an env-sourced token can't reach it.
# credentials: env

# UUIDs of the secrets, each holding one OpenSSH private key
# (BWS secret UUIDs, or Vaultwarden cipher UUIDs when backend: vaultwarden).
secret_ids:
  - 00000000-0000-0000-0000-000000000000

# Optional. Cloud: bitwarden.com | bitwarden.eu. Or a self-hosted host.
# server_endpoint: bitwarden.eu

# Vaultwarden backend (backend: vaultwarden): SSH-key vault items (type 5)
# from a DEDICATED account's personal vault (org-owned items are rejected).
# The server must run with EXPERIMENTAL_CLIENT_FEATURE_FLAGS=ssh-key-vault-item
# to create such items, and the keys must be in OpenSSH private key format.
# Credentials (personal API key + master password) live either in the macOS
# Keychain (credentials: keychain, stored by `tapwarden setup`; every read is
# gated by a Touch ID prompt) or ONLY in the env vars named below
# (credentials: env, the default — for CI / Linux). Never in this file.
# vaultwarden:
#   server_url: https://vault.example.com   # full base URL; serves /identity and /api
#   email: tapwarden@example.com
#   credentials: env                        # keychain | env (default: env)
#   client_id_env: TAPWARDEN_VW_CLIENT_ID              # holds user.<uuid>  (credentials: env only)
#   client_secret_env: TAPWARDEN_VW_CLIENT_SECRET
#   master_password_env: TAPWARDEN_VW_MASTER_PASSWORD

authorization:
  mode: per_use        # per_use = prompt every signature | grace = cache approval
  factor: touch_id     # touch_id (default) | yubikey (FIDO2 security-key touch)
  grace_seconds: 60    # only used when mode = grace
  # For factor: yubikey, register once with `tapwarden register-yubikey` and add:
  # yubikey:
  #   credential_id: <base64 printed by register-yubikey>
  #   public_key:
  #     algorithm: es256
  #     bytes: <base64 printed by register-yubikey>
